-- 1. CREACIÓN DE LA TABLA DE MÉDICOS / ADMINISTRADORES
CREATE TABLE IF NOT EXISTS medicos (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    especialidad VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    config_tiempo_control INT DEFAULT 20,       -- Regla de negocio en minutos
    config_tiempo_procedimiento INT DEFAULT 40   -- Regla de negocio en minutos
);

-- 2. CREACIÓN DE LA TABLA DE PACIENTES / CLIENTES
CREATE TABLE IF NOT EXISTS pacientes (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    whatsapp_id VARCHAR(50) UNIQUE NOT NULL,    -- Identificador único de la API de Meta
    email VARCHAR(100) UNIQUE,
    registrado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 3. CREACIÓN DE LA TABLA DE CITAS Y GESTIÓN DE TURNOS
CREATE TABLE IF NOT EXISTS citas (
    id SERIAL PRIMARY KEY,
    medico_id INT NOT NULL,
    paciente_id INT NOT NULL,
    fecha_hora TIMESTAMP NOT NULL,
    tipo_servicio VARCHAR(50) NOT NULL,
    estado VARCHAR(20) DEFAULT 'programada',
    creado_en TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    
    -- Restricciones de Integridad Referencial (Llaves Foráneas)
    CONSTRAINT fk_medico FOREIGN KEY (medico_id) 
        REFERENCES medicos(id) ON DELETE CASCADE,
    CONSTRAINT fk_paciente FOREIGN KEY (paciente_id) 
        REFERENCES pacientes(id) ON DELETE CASCADE,
        
    -- Restricciones de Validación de Reglas de Negocio
    CONSTRAINT chk_tipo_servicio CHECK (tipo_servicio IN ('control', 'procedimiento')),
    CONSTRAINT chk_estado_cita CHECK (estado IN ('programada', 'cancelada', 'reagendada', 'completada'))
);

